# Database Connections
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/darexai_platform?schema=public"
MONGODB_URL="mongodb://localhost:27017/darexai_platform?directConnection=true"

# Authentication Security
JWT_SECRET="super-secret-jwt-key-change-in-production-12345"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google OAuth PKCE Setup (Required for Google Login, but we also support Mock Login)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Groq API Integration
GROQ_API_KEY="your-groq-api-key"

# WhatsApp Meta Cloud API Integration (Bonus)
WHATSAPP_VERIFY_TOKEN="darexai-whatsapp-token-secret-123"
WHATSAPP_ACCESS_TOKEN="your-meta-access-token"
WHATSAPP_PHONE_NUMBER_ID="your-meta-phone-number-id"
WHATSAPP_AUTO_REPLY="true"


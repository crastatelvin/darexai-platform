datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/mongo-client"
}

model Conversation {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  tenantId  String
  userId    String
  contactId String?
  title     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
}

model Message {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  conversationId String       @db.ObjectId
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         String // "user", "assistant", "system", "contact"
  text           String
  sentiment      String? // "positive", "neutral", "negative"
  intent         String? // "support", "sales", "complaint", "general"
  createdAt      DateTime     @default(now())
}

model TimelineEvent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId  String
  contactId String
  type      String // "whatsapp", "email", "call"
  direction String // "inbound", "outbound"
  title     String
  body      String
  sentiment String?
  intent    String?
  createdAt DateTime @default(now())
}
